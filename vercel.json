{
  "cleanUrls": true,
  "trailingSlash": false,
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/_expo/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!_expo|assets|images|favicon.ico).*)" ,
      "destination": "/index.html"
    }
  ]
}
